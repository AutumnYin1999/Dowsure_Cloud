# ───────────────────────────────────────────────────────────
# 阿里云 ECS 手动部署配置
# 用法：复制本文件为 scripts/deploy.env 后填写下面的值。
#       scripts/deploy.env 已被 .gitignore 忽略，不会提交、不会泄密。
# 这几项与 GitHub Actions 里的 5 个 Secret 一一对应。
# ───────────────────────────────────────────────────────────

# ECS 公网 IP 或域名
ECS_HOST=1.2.3.4

# SSH 端口（默认 22）
ECS_PORT=22

# 登录用户名（如 root / ubuntu）
ECS_USER=root

# 站点目录 = nginx root 指向的独立目录。
# ⚠️ 必须是独立目录（如 /var/www/dowsure），绝不能写 / 或 /var，
#    否则部署时清理旧文件会误删服务器关键目录！
ECS_DEPLOY_PATH=/var/www/dowsure

# SSH 私钥文件路径（OpenSSH 格式）。
# Windows(git-bash) 示例： /c/Users/你的用户名/.ssh/dowsure_ecs
# Linux/Mac 示例：~/.ssh/dowsure_ecs
ECS_SSH_KEY=/path/to/your/private_key

# 站点文件属主（nginx 读取用户），部署后会 chown 回这个用户。默认 www-data。
ECS_WWW_USER=www-data
